# ── Dev (vite) ──
# База API для vite-прокси (dev). Клиент ходит на /api/*, vite проксирует сюда, срезая /api.
VITE_API_URL=http://localhost:8000
# Мок-режим: 1 → хук отдаёт мок-данные без бэкенда (dev-инструмент).
VITE_USE_MOCK=0

# ── Prod (Vercel serverless api/proxy.js) ──
# Адрес Render-сервиса хранения (без /api).
RENDER_API_URL=https://health-storage.onrender.com
# Read-токен (если /read закрыт). Живёт только на сервере, в клиент не попадает.
READ_TOKEN=
